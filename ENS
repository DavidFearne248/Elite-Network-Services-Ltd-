<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Elite Network Services Ltd | Scrap Waste Recycling & Material Recovery</title>
  <meta name="description" content="Elite Network Services Ltd provides scrap waste recycling, material recovery, commercial recycling support and non-hazardous waste collection services." />

  <style>
    :root {
      --black: #101815;
      --dark: #17231e;
      --green: #3f7d58;
      --lime: #9fc46b;
      --cream: #f6f4ec;
      --white: #ffffff;
      --grey: #66736b;
      --border: #dde5dd;
      --shadow: 0 20px 60px rgba(16, 24, 21, 0.14);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      background: var(--cream);
      color: var(--black);
      line-height: 1.6;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    .container {
      width: min(1180px, calc(100% - 32px));
      margin: auto;
    }

    header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(246, 244, 236, 0.94);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }

    .nav {
      height: 82px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .logo-mark {
      width: 54px;
      height: 54px;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--black), var(--green));
      color: var(--white);
      display: grid;
      place-items: center;
      font-weight: 900;
      letter-spacing: 1px;
      box-shadow: var(--shadow);
    }

    .logo strong {
      display: block;
      font-size: 18px;
      line-height: 1.1;
    }

    .logo span {
      display: block;
      color: var(--grey);
      font-size: 13px;
    }

    nav {
      display: flex;
      align-items: center;
      gap: 22px;
      font-weight: 700;
      font-size: 14px;
    }

    nav a:hover {
      color: var(--green);
    }

    .nav-button {
      background: var(--green);
      color: var(--white);
      padding: 12px 18px;
      border-radius: 999px;
    }

    .hero {
      padding: 94px 0 76px;
      background:
        radial-gradient(circle at 15% 15%, rgba(159, 196, 107, 0.28), transparent 32%),
        radial-gradient(circle at 88% 8%, rgba(63, 125, 88, 0.16), transparent 35%),
        linear-gradient(180deg, #ffffff 0%, var(--cream) 100%);
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 54px;
      align-items: center;
    }

    .eyebrow {
      color: var(--green);
      text-transform: uppercase;
      font-weight: 900;
      letter-spacing: 2px;
      font-size: 12px;
      margin-bottom: 14px;
    }

    h1 {
      font-size: clamp(42px, 6vw, 78px);
      line-height: 0.98;
      letter-spacing: -3px;
      margin-bottom: 24px;
      color: var(--black);
    }

    .lead {
      font-size: 20px;
      color: #4f5f55;
      max-width: 700px;
      margin-bottom: 32px;
    }

    .buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-bottom: 30px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 50px;
      padding: 0 24px;
      border-radius: 999px;
      font-weight: 900;
      border: 1px solid transparent;
    }

    .btn-primary {
      background: var(--green);
      color: var(--white);
      box-shadow: 0 14px 28px rgba(63, 125, 88, 0.24);
    }

    .btn-dark {
      background: var(--black);
      color: var(--white);
    }

    .btn-outline {
      background: var(--white);
      border-color: var(--border);
      color: var(--black);
    }

    .trust-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .trust-pills span {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 9px 13px;
      font-weight: 700;
      color: #435047;
      font-size: 14px;
    }

    .quote-card {
      background: var(--dark);
      color: var(--white);
      border-radius: 34px;
      padding: 34px;
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
    }

    .quote-card::after {
      content: "";
      position: absolute;
      right: -80px;
      bottom: -80px;
      width: 220px;
      height: 220px;
      border-radius: 50%;
      background: rgba(159, 196, 107, 0.22);
    }

    .quote-card h2 {
      font-size: 32px;
      line-height: 1.1;
      margin-bottom: 18px;
      position: relative;
      z-index: 2;
    }

    .quote-card ul {
      padding-left: 20px;
      margin-bottom: 24px;
      position: relative;
      z-index: 2;
    }

    .quote-card li {
      margin: 10px 0;
      color: #e8f0e9;
    }

    .quote-card .btn {
      position: relative;
      z-index: 2;
    }

    .strip {
      background: var(--white);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 26px 0;
    }

    .strip-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
    }

    .strip strong {
      display: block;
      color: var(--black);
      font-size: 18px;
    }

    .strip span {
      color: var(--grey);
      font-size: 14px;
    }

    section {
      padding: 88px 0;
    }

    .section-heading {
      max-width: 780px;
      margin-bottom: 42px;
    }

    .section-heading h2,
    .split h2,
    .contact h2 {
      font-size: clamp(34px, 4vw, 54px);
      line-height: 1.05;
      letter-spacing: -2px;
      margin-bottom: 16px;
    }

    .section-heading p {
      color: var(--grey);
      font-size: 18px;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .service-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 28px;
      padding: 30px;
      box-shadow: 0 12px 34px rgba(16, 24, 21, 0.06);
    }

    .service-number {
      width: 46px;
      height: 46px;
      border-radius: 15px;
      background: #eef5e9;
      color: var(--green);
      display: grid;
      place-items: center;
      font-weight: 900;
      margin-bottom: 18px;
    }

    .service-card h3 {
      font-size: 22px;
      margin-bottom: 10px;
    }

    .service-card p {
      color: var(--grey);
    }

    .dark-section {
      background: var(--dark);
      color: var(--white);
    }

    .split {
      display: grid;
      grid-template-columns: 1fr 0.9fr;
      gap: 48px;
      align-items: center;
    }

    .dark-section p {
      color: #d9e4da;
      margin-bottom: 16px;
    }

    .info-box {
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.13);
      border-radius: 30px;
      padding: 30px;
    }

    .info-row {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.14);
      padding: 14px 0;
    }

    .info-row:last-child {
      border-bottom: 0;
    }

    .info-row span {
      color: #bdcabe;
    }

    .info-row strong {
      text-align: right;
    }

    .process-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
    }

    .step {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 26px;
      padding: 26px;
    }

    .step span {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: var(--black);
      color: var(--white);
      display: grid;
      place-items: center;
      font-weight: 900;
      margin-bottom: 16px;
    }

    .step h3 {
      margin-bottom: 8px;
    }

    .step p {
      color: var(--grey);
    }

    .compliance {
      background: #edf2ea;
    }

    .check-list {
      list-style: none;
      margin-top: 24px;
    }

    .check-list li {
      position: relative;
      padding: 8px 0 8px 32px;
      font-weight: 700;
    }

    .check-list li::before {
      content: "✓";
      position: absolute;
      left: 0;
      color: var(--green);
      font-weight: 900;
    }

    .notice {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 28px;
      padding: 30px;
      box-shadow: var(--shadow);
    }

    .notice h3 {
      font-size: 26px;
      margin-bottom: 12px;
    }

    .notice p {
      color: var(--grey);
      margin-bottom: 12px;
    }

    .cta {
      background: linear-gradient(135deg, var(--green), var(--black));
      color: var(--white);
      padding: 54px 0;
    }

    .cta-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 26px;
    }

    .cta h2 {
      font-size: 38px;
      margin-bottom: 6px;
    }

    .cta p {
      color: #e7efe7;
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 0.85fr 1.15fr;
      gap: 44px;
      align-items: start;
    }

    .contact-methods {
      display: grid;
      gap: 12px;
      margin-top: 26px;
    }

    .contact-methods a {
      display: block;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 18px;
    }

    .contact-methods strong {
      display: block;
      color: var(--black);
      margin-bottom: 4px;
    }

    .contact-methods span {
      color: var(--green);
      font-weight: 900;
      word-break: break-word;
    }

    form {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 30px;
      padding: 30px;
      box-shadow: var(--shadow);
    }

    label {
      display: block;
      font-weight: 900;
      margin-bottom: 16px;
    }

    input,
    textarea,
    select {
      width: 100%;
      margin-top: 8px;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 14px 15px;
      font: inherit;
      background: #fbfcf8;
    }

    textarea {
      resize: vertical;
    }

    .form-note {
      font-size: 13px;
      color: var(--grey);
      margin-top: 14px;
    }

    footer {
      background: #0d1411;
      color: #dce6dc;
      padding: 34px 0;
    }

    .footer-grid {
      display: flex;
      justify-content: space-between;
      gap: 24px;
    }

    footer p {
      color: #aebbae;
      margin-top: 4px;
    }

    @media (max-width: 900px) {
      nav {
        display: none;
      }

      .hero-grid,
      .split,
      .contact-grid {
        grid-template-columns: 1fr;
      }

      .services-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .process-grid,
      .strip-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .cta-inner,
      .footer-grid {
        display: block;
      }
    }

    @media (max-width: 560px) {
      .container {
        width: min(100% - 24px, 1180px);
      }

      .hero {
        padding: 58px 0;
      }

      section {
        padding: 58px 0;
      }

      h1 {
        letter-spacing: -2px;
      }

      .buttons .btn {
        width: 100%;
      }

      .services-grid,
      .process-grid,
      .strip-grid {
        grid-template-columns: 1fr;
      }

      .logo strong {
        font-size: 15px;
      }
    }
  </style>
</head>

<body>
  <header>
    <div class="container nav">
      <a href="#top" class="logo">
        <div class="logo-mark">ENS</div>
        <div>
          <strong>Elite Network Services Ltd</strong>
          <span>Scrap Waste Recycling</span>
        </div>
      </a>

      <nav>
        <a href="#services">Services</a>
        <a href="#about">About</a>
        <a href="#process">How It Works</a>
        <a href="#company">Company Info</a>
        <a href="#contact" class="nav-button">Get a Quote</a>
      </nav>
    </div>
  </header>

  <main id="top">
    <section class="hero">
      <div class="container hero-grid">
        <div>
          <p class="eyebrow">Registered UK Limited Company • Company No. 15265839</p>
          <h1>Scrap Waste Recycling & Material Recovery Services</h1>
          <p class="lead">
            Elite Network Services Ltd provides professional scrap waste recycling, material recovery and commercial recycling support for customers who need a reliable and straightforward service.
          </p>

          <div class="buttons">
            <a href="tel:07553337751" class="btn btn-primary">Call 07553 337751</a>
            <a href="mailto:elite.network.services@hotmail.com" class="btn btn-outline">Email Us</a>
          </div>

          <div class="trust-pills">
            <span>Commercial & Domestic</span>
            <span>Scrap Waste Recycling</span>
            <span>Material Recovery</span>
            <span>Fast Enquiries</span>
          </div>
        </div>

        <div class="quote-card">
          <h2>Need a recycling quote?</h2>
          <ul>
            <li>Tell us what material you have</li>
            <li>Send approximate quantity and location</li>
            <li>Receive clear next steps</li>
            <li>Arrange collection where suitable</li>
          </ul>
          <a href="#contact" class="btn btn-primary">Request a Quote</a>
        </div>
      </div>
    </section>

    <div class="strip">
      <div class="container strip-grid">
        <div>
          <strong>Reliable Service</strong>
          <span>Clear communication from enquiry to collection.</span>
        </div>
        <div>
          <strong>Recycling Focused</strong>
          <span>Helping recover useful materials from waste.</span>
        </div>
        <div>
          <strong>Business Ready</strong>
          <span>Supporting commercial and industrial customers.</span>
        </div>
        <div>
          <strong>Genuine Company</strong>
          <span>UK limited company details displayed clearly.</span>
        </div>
      </div>
    </div>

    <section id="services">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">What we do</p>
          <h2>Professional recycling and waste support</h2>
          <p>
            We help customers deal with scrap waste and recyclable materials in a practical, professional and responsible way.
          </p>
        </div>

        <div class="services-grid">
          <div class="service-card">
            <div class="service-number">01</div>
            <h3>Scrap Waste Recycling</h3>
            <p>Support with recyclable scrap waste from commercial, domestic and industrial customers.</p>
          </div>

          <div class="service-card">
            <div class="service-number">02</div>
            <h3>Material Recovery</h3>
            <p>Sorting and recovery of usable materials from suitable waste streams wherever possible.</p>
          </div>

          <div class="service-card">
            <div class="service-number">03</div>
            <h3>Commercial Recycling</h3>
            <p>Recycling support for offices, workshops, trades, yards, warehouses and business premises.</p>
          </div>

          <div class="service-card">
            <div class="service-number">04</div>
            <h3>Industrial Scrap Handling</h3>
            <p>Support with recyclable industrial scrap, surplus materials and site clearance enquiries.</p>
          </div>

          <div class="service-card">
            <div class="service-number">05</div>
            <h3>Non-Hazardous Waste Collection</h3>
            <p>Collection support for suitable non-hazardous recyclable waste, subject to assessment.</p>
          </div>

          <div class="service-card">
            <div class="service-number">06</div>
            <h3>Waste & Scrap Brokerage</h3>
            <p>Helping customers find practical routes for recyclable materials, scrap and reusable waste.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="dark-section">
      <div class="container split">
        <div>
          <p class="eyebrow">About us</p>
          <h2>Responsible scrap waste recycling with a professional approach.</h2>
          <p>
            Elite Network Services Ltd is focused on scrap waste recycling and material recovery. Our aim is to provide a reliable service that helps customers manage recyclable waste efficiently.
          </p>
          <p>
            We work with customers who need clear communication, simple quoting and practical support for scrap, recyclable materials and non-hazardous waste enquiries.
          </p>
          <p>
            Whether you are a business, tradesperson, industrial site or domestic customer, we welcome enquiries and will advise on the best next step.
          </p>
        </div>

        <div class="info-box">
          <div class="info-row">
            <span>Company Name</span>
            <strong>Elite Network Services Ltd</strong>
          </div>
          <div class="info-row">
            <span>Company Number</span>
            <strong>15265839</strong>
          </div>
          <div class="info-row">
            <span>Main Activity</span>
            <strong>Scrap Waste Recycling</strong>
          </div>
          <div class="info-row">
            <span>Phone</span>
            <strong>07553 337751</strong>
          </div>
          <div class="info-row">
            <span>Email</span>
            <strong>elite.network.services@hotmail.com</strong>
          </div>
        </div>
      </div>
    </section>

    <section id="process">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">How it works</p>
          <h2>A simple process from enquiry to collection</h2>
          <p>
            We make it easy to discuss your recycling requirement and understand the next steps.
          </p>
        </div>

        <div class="process-grid">
          <div class="step">
            <span>1</span>
            <h3>Contact Us</h3>
            <p>Call or email with details of the material, quantity and location.</p>
          </div>

          <div class="step">
            <span>2</span>
            <h3>Assessment</h3>
            <p>We review the type of scrap or recyclable waste and your collection needs.</p>
          </div>

          <div class="step">
            <span>3</span>
            <h3>Quote</h3>
            <p>We provide clear guidance or a quote depending on the material and service required.</p>
          </div>

          <div class="step">
            <span>4</span>
            <h3>Collection</h3>
            <p>Where suitable, collection or recycling support is arranged professionally.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="company" class="compliance">
      <div class="container split">
        <div>
          <p class="eyebrow">Company information</p>
          <h2>Built to show customers they are dealing with a genuine company.</h2>
          <p>
            A professional online presence helps customers, suppliers and partners quickly understand who the company is, what it does and how to make contact.
          </p>

          <ul class="check-list">
            <li>Registered UK limited company</li>
            <li>Company number shown clearly</li>
            <li>Direct phone and email contact details</li>
            <li>Clear service descriptions</li>
            <li>Quote request section for new enquiries</li>
            <li>Professional recycling and recovery messaging</li>
          </ul>
        </div>

        <div class="notice">
          <h3>Compliance note</h3>
          <p>
            Businesses that carry, broker, deal in or dispose of waste may need the correct Environment Agency registration, waste carrier registration, scrap metal dealer licence or other permissions depending on the exact activity.
          </p>
          <p>
            Customers should confirm requirements before operating, collecting or handling controlled waste.
          </p>
        </div>
      </div>
    </section>

    <section class="cta">
      <div class="container cta-inner">
        <div>
          <h2>Have scrap or recyclable waste?</h2>
          <p>Contact Elite Network Services Ltd today to discuss your requirements.</p>
        </div>
        <a href="#contact" class="btn btn-outline">Request a Quote</a>
      </div>
    </section>

    <section id="contact" class="contact">
      <div class="container contact-grid">
        <div>
          <p class="eyebrow">Contact</p>
          <h2>Request a quote today</h2>
          <p>
            Send details of the scrap or recyclable waste, approximate quantity, location and preferred collection time.
          </p>

          <div class="contact-methods">
            <a href="tel:07553337751">
              <strong>Phone</strong>
              <span>07553 337751</span>
            </a>

            <a href="mailto:elite.network.services@hotmail.com">
              <strong>Email</strong>
              <span>elite.network.services@hotmail.com</span>
            </a>
          </div>
        </div>

        <form action="mailto:elite.network.services@hotmail.com" method="post" enctype="text/plain">
          <label>
            Your Name
            <input type="text" name="name" placeholder="Your name" />
          </label>

          <label>
            Phone Number
            <input type="tel" name="phone" placeholder="Your phone number" />
          </label>

          <label>
            Email Address
            <input type="email" name="email" placeholder="Your email address" />
          </label>

          <label>
            Service Required
            <select name="service">
              <option>Scrap waste recycling</option>
              <option>Material recovery</option>
              <option>Commercial recycling support</option>
              <option>Industrial scrap handling</option>
              <option>Non-hazardous waste collection</option>
              <option>Other enquiry</option>
            </select>
          </label>

          <label>
            Enquiry Details
            <textarea name="message" rows="6" placeholder="Tell us what material you have, approximate quantity and location"></textarea>
          </label>

          <button type="submit" class="btn btn-primary">Send Enquiry</button>

          <p class="form-note">
            This form opens the customer's email app. For a fully live form, connect the site to a form service after deployment.
          </p>
        </form>
      </div>
    </section>
  </main>

  <footer>
    <div class="container footer-grid">
      <div>
        <strong>Elite Network Services Ltd</strong>
        <p>Scrap Waste Recycling & Material Recovery Services</p>
      </div>

      <div>
        <p>Company No. 15265839</p>
        <p>Phone: 07553 337751</p>
        <p>Email: elite.network.services@hotmail.com</p>
      </div>
    </div>
  </footer>
</body>
</html>
